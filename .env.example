PORT=3000

# GitHub App settings
GITHUB_APP_ID=1234567
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# Or provide a base64-encoded PEM instead of GITHUB_PRIVATE_KEY
GITHUB_PRIVATE_KEY_BASE64=
GITHUB_WEBHOOK_SECRET=replace-me
GITHUB_BOT_HANDLE=aud-it
GITHUB_ALLOWED_BASE_BRANCHES=main
# Optional comma-separated allowlist, e.g. mantle/mantle-v2,mantle/another-repo
GITHUB_ALLOWED_REPOS=
# Optional comma-separated allowlist of GitHub logins allowed to talk to the bot
GITHUB_ALLOWED_INTERACTORS=
# Allowed comment author_association values for bot interaction
GITHUB_ALLOWED_AUTHOR_ASSOCIATIONS=OWNER,MEMBER,COLLABORATOR

# OpenAI settings
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
OPENAI_MODEL=gpt-5-mini
OPENAI_MAX_OUTPUT_TOKENS=4000
OPENAI_TIMEOUT_MS=120000
OPENAI_MAX_RETRIES=2
OPENAI_FORCE_STREAM=false

# Review behavior
REVIEW_MAX_FILES=40
REVIEW_MAX_PATCH_CHARS=120000
REVIEW_MAX_INLINE_COMMENTS=6
REVIEW_MIN_CONFIDENCE=0.72
REVIEW_SUMMARY_ONLY=false
REVIEW_COMMENT_ON_CLEAN=true
REVIEW_IGNORE_DRAFTS=true
REVIEW_IGNORE_PATTERNS=**/*.lock,**/package-lock.json,**/pnpm-lock.yaml,**/yarn.lock,**/bun.lockb,**/*.min.js,**/*.map,**/dist/**,**/build/**,**/coverage/**,**/vendor/**,**/node_modules/**
